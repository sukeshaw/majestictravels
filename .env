# =====================================================
# Majestic Holidays Website - Environment Configuration
# =====================================================
# Copy this file to .env and fill in your actual values
# NEVER commit the actual .env file to version control

# =====================================================
# SERVER CONFIGURATION
# =====================================================

# Port on which the server runs
PORT=5000

# Environment mode: development, staging, production
NODE_ENV=development

# Frontend URL (for CORS and redirects)
FRONTEND_URL=http://localhost:8000

# =====================================================
# DATABASE CONFIGURATION (MySQL)
# =====================================================

# MySQL Host
DB_HOST=localhost

# MySQL Port (default: 3306)
DB_PORT=3306

# MySQL Username
DB_USER=root

# MySQL Password
DB_PASSWORD=your_password_here

# MySQL Database Name
DB_NAME=travel_agency

# Connection Pool Settings
DB_CONNECTION_LIMIT=10
DB_QUEUE_LIMIT=0

# =====================================================
# EMAIL CONFIGURATION - OPTION A: Using Gmail
# =====================================================

# Gmail address (sender email)
EMAIL_USER=majestickakkodi@gmail.com

# Gmail App Password (16 characters, generated from Google Account)
# Get it from: https://myaccount.google.com/apppasswords
EMAIL_PASSWORD=

# Email service provider
EMAIL_SERVICE=gmail

# Resend email configuration
# RESEND_API_KEY should be generated from https://resend.com
# RESEND_FROM_EMAIL should be a verified sender address
RESEND_API_KEY=re_EXGQ8wuu_2xy1DmTjuUFRFPpPQ72Xjc91
RESEND_FROM_EMAIL=noreply@majesticholidays.online

# =====================================================
# EMAIL CONFIGURATION - OPTION C: Using Mailgun
# =====================================================
# Uncomment these if using Mailgun

# MAILGUN_DOMAIN=mg.Majestic Holidays.com
# MAILGUN_API_KEY=your_mailgun_api_key_here

# =====================================================
# RECIPIENT EMAIL ADDRESSES
# =====================================================

# Admin email where enquiries are sent
ADMIN_EMAIL=admin@majesticholidays.online.com

# Support email for contact form replies
SUPPORT_EMAIL=support@majesticholidays.online.com

# Enquiries email for tour/cab/bus enquiries
ENQUIRY_EMAIL=enquiry@majesticholidays.online.com

# =====================================================
# CONTACT INFORMATION (Display on Website)
# =====================================================

# Company Name
COMPANY_NAME=Majestic Holidays

# Office Phone
OFFICE_PHONE=+91-800-123-4567

# Mobile Phone
MOBILE_PHONE=+91-9876-543-210

# Support Phone
SUPPORT_PHONE=+91-9000-000-001

# Office Address
OFFICE_ADDRESS=123 Tour Street, Kozhikode, Kerala 673001, India

# Website
WEBSITE=https://majesticholidays.online.com

# =====================================================
# SECURITY SETTINGS
# =====================================================

# JWT Secret (for future authentication)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# CORS Origins (comma-separated for multiple)
CORS_ORIGINS=http://localhost:8000,http://localhost:3000,https://majesticholidays.online

# Rate Limiting - Enquiry Forms (requests per 15 minutes)
RATE_LIMIT_ENQUIRY=5

# Rate Limiting - Contact Form (requests per 15 minutes)
RATE_LIMIT_CONTACT=3

# =====================================================
# NOTIFICATION SETTINGS
# =====================================================

# Send email to admin on new enquiry
NOTIFY_ADMIN_ON_ENQUIRY=true

# Send confirmation email to customer
NOTIFY_CUSTOMER_ON_ENQUIRY=true

# Send auto-response to contact form
NOTIFY_CONTACT_AUTO_REPLY=true

# =====================================================
# PAYMENT CONFIGURATION (For Future Integration)
# =====================================================

# Razorpay Keys
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=xxxxx

# =====================================================
# API KEYS FOR FUTURE INTEGRATIONS
# =====================================================

# Google Maps API Key (for location features)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Google Analytics ID
GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X

# Sentry DSN (for error tracking)
SENTRY_DSN=your_sentry_dsn_url

# =====================================================
# LOGGING CONFIGURATION
# =====================================================

# Log Level: error, warn, info, debug
LOG_LEVEL=info

# Log File Path
LOG_FILE=./logs/app.log

# =====================================================
# FEATURE FLAGS
# =====================================================

# Enable/disable specific features
ENABLE_TOUR_BOOKING=true
ENABLE_CAB_BOOKING=true
ENABLE_BUS_BOOKING=true
ENABLE_LIVE_CHAT=false
ENABLE_REFUND_REQUESTS=true

# =====================================================
# DATABASE BACKUP (Optional)
# =====================================================

# Backup directory path
BACKUP_DIR=./backups

# Enable automatic daily backups
AUTO_BACKUP_ENABLED=false


SUPABASE_URL=https://wfekuscysmxcnnqiyaem.supabase.co
SUPABASE_ANON_KEY=sb_publishable_sQfnjV0_dC1h0oXY3KmTLg_oIsVlMb0

# =====================================================
# PRODUCTION SETTINGS
# =====================================================
# Use these values when deploying to production

# SSL Certificate Path
# SSL_CERT_PATH=/etc/ssl/certs/travelventures.com.crt
# SSL_KEY_PATH=/etc/ssl/private/travelventures.com.key

# Production Database URL (for PaaS providers)
# DATABASE_URL=mysql://user:password@host:3306/travel_agency

# Redis Cache (optional, for scaling)
# REDIS_URL=redis://localhost:6379

# =====================================================
# NOTES
# =====================================================
# 
# 1. GMAIL SETUP:
#    - Enable 2-Factor Authentication in Google Account
#    - Go to myaccount.google.com/apppasswords
#    - Select "Mail" and "Windows Computer"
#    - Copy the 16-character password
#
# 2. EMAIL SETUP:
#    - Create a Resend account at https://resend.com
#    - Generate an API key and set RESEND_API_KEY
#    - Set RESEND_FROM_EMAIL to a verified sender address
#
# 3. DATABASE:
#    - Make sure MySQL is running
#    - Database must exist before running the app
#    - Check DB credentials are correct
#
# 4. SECURITY:
#    - Change JWT_SECRET to a random string
#    - Use strong DB password
#    - Never commit this file to Git
#    - Add .env to .gitignore
#
# 5. RATE LIMITING:
#    - Adjust values based on expected traffic
#    - Higher numbers = more relaxed limits
#
# =====================================================

# =====================================================
# TROUBLESHOOTING
# =====================================================
#
# If emails not sending:
# - Verify EMAIL_USER and EMAIL_PASSWORD
# - For Gmail: App password must be 16 characters
# - Check admin email is valid
# - Look for errors in server logs
#
# If database connection fails:
# - Verify MySQL is running
# - Check credentials are correct
# - Ensure database exists
# - Verify port is 3306 (default)
#
# If CORS errors occur:
# - Check FRONTEND_URL matches your frontend
# - Add your domain to CORS_ORIGINS
# - Restart the server after changes
#
# =====================================================
